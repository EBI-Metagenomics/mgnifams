includeConfig "${launchDir}/subworkflows/generate_families/nextflow.config"

profiles {
    slurm {
        params {
            matched_anti_defence_proteins = "/nfs/production/rdf/metagenomics/users/vangelis/khalifams/data/output/khalifams/matched_cluster_reps.csv"
            clusters_tsv = "/nfs/production/rdf/metagenomics/users/vangelis/mgnifams/data/output/mmseqs/mmseqs_families.tsv"
            empty_file = "/nfs/production/rdf/metagenomics/users/vangelis/empty.txt"
            // manually update from previous run output or for fresh start:
            refined_families_tsv = "/nfs/production/rdf/metagenomics/users/vangelis/khalifams/data/output/input/families/refined_families.tsv"
            mgnifams_dict_fasta_path = "/nfs/production/rdf/metagenomics/users/vangelis/khalifams/data/output/input/families/mgnifams_dict.fa"
            discarded_clusters_txt = "/nfs/production/rdf/metagenomics/users/vangelis/khalifams/data/output/input/families/discarded_clusters.txt"
            converged_families_txt = "/nfs/production/rdf/metagenomics/users/vangelis/khalifams/data/output/input/families/converged_families.txt"
        }
    }
    local {
        params {
            matched_anti_defence_proteins = "${launchDir}/data/output/khalifams/matched_cluster_reps.csv"
            clusters_tsv = "${launchDir}/data/output/mmseqs/mmseqs_families.tsv"
            empty_file = "${launchDir}/test-data/empty.txt"
            // manually update from previous run output or for fresh start:
            refined_families_tsv     = "${launchDir}/data/output/khalifams/input/families/refined_families.tsv"
            mgnifams_dict_fasta_path = "${launchDir}/data/output/khalifams/input/families/mgnifams_dict.fa"
            discarded_clusters_txt   = "${launchDir}/data/output/khalifams/input/families/discarded_clusters.txt"
            converged_families_txt   = "${launchDir}/data/output/khalifams/input/families/converged_families.txt"
        }
    }
}
