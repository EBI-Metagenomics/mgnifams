/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running local tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a local pipeline test.

    Use as follows:
        nextflow run ebi-metagenomics/mgnifams -profile test_update

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '30.GB',
        time: '2.h'
    ]
}

params {

    // Input options
    input = "${projectDir}/assets/samplesheet_initialise_sqlite.csv"
    mode  = 'initialise_mgnifams_db'

    // Boilerplate options
    outdir = "${launchDir}/output"

}
