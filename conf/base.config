/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    ebi-metagenomics/mgnifams Nextflow base config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    A 'blank slate' config file, appropriate for general use on most high performance
    compute environments. Assumes that all software is installed and available on
    the PATH. Runs in `local` mode - all jobs will be run on the logged in environment.
----------------------------------------------------------------------------------------
*/

process {

    cpus   = { 1      * task.attempt }
    memory = { 6.GB   * task.attempt }
    time   = { 4.h    * task.attempt }

    errorStrategy = { task.exitStatus in ((130..145) + 104 + 175) ? 'finish' : 'finish' } // TODO ? 'retry' : 'finish' // when cache is fixed
    maxRetries    = 0 // until the cache not resuming error is addressed
    maxErrors     = '-1'

    // Process-specific resource requirements
    // NOTE - Please try and reuse the labels below as much as possible.
    //        These labels are used and recognised by default in DSL2 files hosted on nf-core/modules.
    //        If possible, it would be nice to keep the same label naming convention when
    //        adding in your local modules too.
    // See https://www.nextflow.io/docs/latest/config.html#config-process-selectors
    withLabel:process_single {
        cpus   = { 1                   }
        memory = { 6.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withLabel:process_low {
        cpus   = { 2     * task.attempt }
        memory = { 12.GB * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel:process_medium {
        cpus   = { 6     * task.attempt }
        memory = { 36.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withLabel:process_high {
        cpus   = { 12    * task.attempt }
        memory = { 72.GB * task.attempt }
        time   = { 16.h  * task.attempt }
    }
    withLabel:process_long {
        time   = { 20.h  * task.attempt }
    }
    withLabel:process_high_memory {
        memory = { 200.GB * task.attempt }
    }
    withLabel:error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }
    withLabel: process_gpu {
        ext.use_gpu = { workflow.profile.contains('gpu') }
        accelerator = { workflow.profile.contains('gpu') ? 1 : null }
    }

    // SETUP_CLUSTERS
    // extract_unannotated_fasta
    withName: PIGZ_UNCOMPRESS                { cpus = 8; memory = '50.0 MB'; time = '5h' }
    withName: BZ2_UNCOMPRESS                 { memory = '50.0 MB'; time = '5h' }
    withName: EXTRACT_UNANNOTATED_SLICES     { memory = '60.0 MB'; time = '1h' }
    // check_quality
    withName: SEQKIT_STATS                   { memory = '2.0 GB' ; time = '30m' }
    withName: SEQKIT_STATS_TO_MQC            { memory = '10.0 MB'; time = '5m'  }
    // execute_clustering
    withName: MMSEQS_CREATEDB                { memory = '36.0 GB'; time = '1h' }
    withName: MMSEQS_LINCLUST                { cpus = 8; memory = '180.0 GB'; time = '3h'  }
    withName: MMSEQS_CREATETSV               { cpus = 2; memory = '65.0 GB' ; time = '20m' }
    // post clustering
    withName: CALCULATE_CLUSTER_DISTRIBUTION { memory = '24.0 GB'; time = '15m' }
    withName: EXTRACT_UNIQUE_CLUSTER_REPS    { memory = '32.0 GB'; time = '30m' }
    withName: CHUNK_CLUSTERS                 { memory = '40.0 MB'; time = '15m' }

    // GENERATE_NONREDUNDANT_FAMILIES
    // generate_families
    withName:GENERATE_FAMILIES {
        cpus       = 4
        memory     = { 1400.GB * task.attempt } // >468GB -> bigmem
        time       = { 72.h   * task.attempt }
        maxRetries = 3
    }
    // remove_redundancy
    withName: FIND_CONCATENATE               { memory = '4.0 GB'  ; time = '2h'  }
    withName: HMMER_HMMSEARCH                { memory = '12.0 GB' ; time = '10h' }
    withName: POOL_PREREDUNDANT_FAMILIES_TSV { memory = '2.0 GB'  ; time = '2h'  }
    withName: IDENTIFY_REDUNDANT_FAMS        { memory = '700.0 GB'; time = '24h' }
    withName: POOL_NONREDUNDANT_FAMILIES     { memory = '470.0 GB'; time = '48h' }
    // post redundancy-removal
    withName: REFORMAT_SEED_MSA          { memory = '200.0 MB'; time = '5m'  }
    withName: REFORMAT_FULL_MSA          { memory = '18.0 GB' ; time = '30m' }
    withName: PRESENT_DISCARDED_FAMILIES { memory = '2.0 GB'  ; time = '10m' }
    withName: PRESENT_FAMILY_METADATA    { memory = '2.0 GB'  ; time = '10m' }

    // PREDICT_STRUCTURES
    withName: RUN_ESMFOLD            { memory = '60.0 GB'; time = '2h' }
    withName: EXTRACT_CUDA_FAILED    { memory = '1.0 GB' ; time = '5m' }
    withName: RUN_ESMFOLD_CPU        { cpus = 16; memory = '320.0 GB'; time = '8h' }
    withName: EXTRACT_ESMFOLD_SCORES { memory = '1.0 GB'; time = '5m' }
    withName: PARSE_CIF              { memory = '1.0 GB'; time = '5m' }

    // ANNOTATE_FAMILIES
    // annotate_reps
    withName: S4PRED_RUNMODEL                 { memory = '6.0 GB' ; time = '12h' }
    withName: PARSE_S4PRED_TO_FEATURE_VIEWER  { memory = '1.0 GB' ; time = '2h'  }
    withName: DEEPTMHMM_PREDICT               { memory = '50.0 GB'; time = '10h' }
    // annotate_models
    withName: HHSUITE_REFORMAT                { memory = '2.0 GB' ; time = '5m'  }
    withName: HHSUITE_HHBLITS                 { memory = '10.0 GB'; time = '10m' }
    withName: HHSUITE_HHSEARCH                { memory = '10.0 GB'; time = '10m' }
    // annotate_structures
    withName: FOLDSEEK_EASYSEARCH_PDB         { cpus = 4 ; memory = '50.0 GB' ; time = '2h'  }
    withName: FOLDSEEK_EASYSEARCH_ALPHAFOLDDB { cpus = 32; memory = '900.0 GB'; time = '90h' }

    // EXPORT_DATA 
    withName: EXPORT_MGNIFAMS       { memory = '1.0 GB'  ; time = '5m' }
    withName: FILTER_EXPORT_PFAMS   { memory = '200.0 MB'; time = '5m' }
    withName: FILTER_EXPORT_FUNFAMS { memory = '200.0 MB'; time = '5m' }
    withName: EXPORT_MODEL_PFAMS    { memory = '40.0 MB' ; time = '5m' }
    withName: EXPORT_FOLDS          { memory = '200.0 MB'; time = '5m' }

    // INIT_DB 
    withName: INIT_SQLITE    { memory = '10.0 MB'; time = '5m' }
    withName: IMPORT_QUERIES { memory = '6.0 GB' ; time = '5m' }

    // UPDATE_DB
    withName: QUERY_MGNPROTEIN_DB { cpus = 24; memory = '280.0 GB'; time = '100h' }
    withName: PARSE_DOMAINS       { cpus = 4;  memory = '6.0 GB'  ; time = '2h'   }
    withName: PARSE_BIOMES        { memory = '2.0 GB'; time = '1h'  }
    withName: UPDATE_SQLITE_BLOBS { memory = '6.0 GB'; time = '10h' }
}
