/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running local tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a local pipeline test.

    Use as follows:
        nextflow run ebi-metagenomics/mgnifams -profile test

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '30.GB',
        time: '2.h'
    ]
}

params {

    // Input options
    input         = "${projectDir}/assets/samplesheet.csv"
    compress_mode = 'gz' // 'none' // 1. gz, 2. bz2 or 3. anything else (ignores decompress)
    
    // SETUP_CLUSTERS
    // extract_unannotated_fasta
    input_csv_chunk_size = 50000
    // post clustering
    minimum_members      = 5
    clusters_chunk_size  = 4

    // GENERATE_NONREDUNDANT_FAMILIES
    // remove_redundancy
    starting_id = 1

    // PREDICT_STRUCTURES
    pdb_chunk_size      = 5
    pdb_chunk_size_long = 2

    // ANNOTATE_FAMILIES
    // annotate_models
    hh_mode                = 'hhblits'
    // annotate_structures
    foldseek_evalue_cutoff = 30

    // Boilerplate options
    outdir = "${launchDir}/output"

}

process {

    // SETUP_CLUSTERS
    // execute_clustering
    withName: MMSEQS_CREATEDB  { memory = '12.0 GB' }
    withName: MMSEQS_LINCLUST  { cpus = 8; memory = '10.0 GB' }
    withName: MMSEQS_CREATETSV { cpus = 2; memory = '2.0 GB' }

    // GENERATE_NONREDUNDANT_FAMILIES
    // generate_families_parallel
    withName: CHUNK_CLUSTERS    { memory = '10.0 GB' }
    withName: GENERATE_FAMILIES { cpus = 1; memory = '6.0 GB' } 

    // PREDICT_STRUCTURES
    withName: RUN_ESMFOLD_CPU { memory = '26.0 GB' }

    // ANNOTATE_FAMILIES
    // annotate_structures
    withName: FOLDSEEK_EASYSEARCH                  { memory = '5.0 GB' }

}

